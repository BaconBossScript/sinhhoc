let pool=[], cur=0, answered=[], correct=0, wrong=0;
let curBai='ALL', curType='ALL';

function buildPool(){
  let mc_f = curType==='MC'||curType==='ALL';
  let tf_f = curType==='TF'||curType==='ALL';
  let sa_f = curType==='SA'||curType==='ALL';
  pool = [];
  if(mc_f) MC.forEach(q=>{ if(curBai==='ALL'||q.b===curBai) pool.push({...q,type:'MC'}); });
  if(tf_f) TF.forEach(q=>{ if(curBai==='ALL'||q.b===curBai) pool.push({...q,type:'TF'}); });
  if(sa_f) SA.forEach(q=>{ if(curBai==='ALL'||q.b===curBai) pool.push({...q,type:'SA'}); });
  cur=0; answered=new Array(pool.length).fill(null); correct=0; wrong=0;
  document.getElementById('s-correct').textContent=0;
  document.getElementById('s-wrong').textContent=0;
  document.getElementById('s-total').textContent=pool.length;
  document.getElementById('nav').style.display='flex';
  document.getElementById('explain').style.display='none';
  render();
}

function setBai(b){
  curBai=b;
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
  const sel = b==='ALL'?'ALL':b;
  document.querySelectorAll('.tab').forEach(t=>{ if(t.textContent.trim()===(b==='ALL'?'Tất cả':'B'+b)) t.classList.add('active'); });
  document.getElementById('subtitle').textContent = b==='ALL' ? 'Tất cả bài học' : `Bài ${b}`;
  buildPool();
}

function setType(tp){
  curType=tp;
  document.querySelectorAll('.ttab').forEach(t=>t.className='ttab');
  const map={'MC':'active-mc','TF':'active-tf','SA':'active-sa','ALL':'active-all'};
  document.querySelectorAll('.ttab').forEach(t=>{
    const labels={'MC':'Trắc nghiệm','TF':'Đúng / Sai','SA':'Trả lời ngắn','ALL':'Tất cả'};
    if(t.textContent.trim()===labels[tp]) t.classList.add(map[tp]);
  });
  buildPool();
}

function render(){
  if(!pool.length){ document.getElementById('qtext').textContent='Không có câu hỏi phù hợp. Thử chọn bài khác hoặc loại câu hỏi khác.'; document.getElementById('q-body').innerHTML=''; return; }
  const q=pool[cur];
  const pct=((cur+1)/pool.length*100).toFixed(1);
  document.getElementById('prog-fill').style.width=pct+'%';
  document.getElementById('prog-label').textContent=(cur+1)+' / '+pool.length;
  const typeMap={'MC':'Trắc nghiệm','TF':'Đúng / Sai','SA':'Trả lời ngắn'};
  const typeClass={'MC':'badge-mc','TF':'badge-tf','SA':'badge-sa'};
  const bt=document.getElementById('b-type');
  bt.textContent=typeMap[q.type]; bt.className='badge '+typeClass[q.type];
  const bb=document.getElementById('b-bai');
  bb.textContent='Bài '+q.b;
  document.getElementById('b-num').textContent=(cur+1)+' / '+pool.length;
  document.getElementById('qtext').textContent=q.q;
  document.getElementById('explain').style.display='none';
  document.getElementById('btn-prev').style.display=cur>0?'':'none';
  document.getElementById('btn-next').style.display=answered[cur]!==null?'':'none';
  document.getElementById('btn-next').textContent=cur===pool.length-1?'Xem kết quả':'Tiếp →';
  document.getElementById('nav-info').textContent='';

  if(q.type==='MC') renderMC(q);
  else if(q.type==='TF') renderTF(q);
  else renderSA(q);
}

function renderMC(q){
  const body=document.getElementById('q-body');
  body.innerHTML='';
  const div=document.createElement('div'); div.className='opts';
  q.o.forEach((o,i)=>{
    const btn=document.createElement('button'); btn.className='opt';
    const k=document.createElement('span'); k.className='opt-key'; k.textContent=['A','B','C','D'][i];
    const tx=document.createElement('span'); tx.textContent=o;
    btn.appendChild(k); btn.appendChild(tx);
    if(answered[cur]!==null){
      btn.disabled=true;
      if(i===q.a) btn.classList.add('correct');
      else if(i===answered[cur]) btn.classList.add('wrong');
    } else { btn.onclick=()=>answerMC(i); }
    div.appendChild(btn);
  });
  body.appendChild(div);
  if(answered[cur]!==null){ const ex=document.getElementById('explain'); ex.style.display='block'; ex.textContent='💡 '+q.e; }
}

function answerMC(i){
  if(answered[cur]!==null) return;
  answered[cur]=i;
  if(i===pool[cur].a){ correct++; document.getElementById('s-correct').textContent=correct; document.getElementById('nav-info').textContent='✓ Đúng!'; }
  else{ wrong++; document.getElementById('s-wrong').textContent=wrong; document.getElementById('nav-info').textContent='✗ Sai'; }
  document.getElementById('btn-next').style.display='';
  renderMC(pool[cur]);
}

function renderTF(q){
  const body=document.getElementById('q-body');
  body.innerHTML='';
  const grid=document.createElement('div'); grid.className='tf-opts';
  const stmts=q.stmts;
  const userAnswers = answered[cur] || new Array(stmts.length).fill(null);
  const revealed = answered[cur] && answered[cur].every(a=>a!==null);

  stmts.forEach((s,i)=>{
    const card=document.createElement('div'); card.className='tf-item';
    const stmt=document.createElement('div'); stmt.className='tf-stmt';
    stmt.innerHTML='<strong>'+s.t.charAt(0)+'.</strong>'+s.t.slice(1);
    const btns=document.createElement('div'); btns.className='tf-btns';
    const tBtn=document.createElement('button'); tBtn.className='tf-btn t-btn'; tBtn.textContent='Đúng';
    const fBtn=document.createElement('button'); fBtn.className='tf-btn f-btn'; fBtn.textContent='Sai';

    if(revealed){
      tBtn.disabled=true; fBtn.disabled=true;
      if(s.a){ tBtn.classList.add('reveal-t'); } else { fBtn.classList.add('reveal-f'); }
      if(userAnswers[i]===true) tBtn.classList.add('selected-t');
      else if(userAnswers[i]===false) fBtn.classList.add('selected-f');
      // show result
      const rrow=document.createElement('div'); rrow.className='tf-result-row';
      const correct_ans=s.a;
      const user_ans=userAnswers[i];
      const isOk=user_ans===correct_ans;
      rrow.innerHTML='<span class="tf-check '+(isOk?'ok':'no')+'">'+(isOk?'✓':'✗')+'</span><span class="tf-note">'+s.e+'</span>';
      card.appendChild(stmt); card.appendChild(btns); card.appendChild(rrow);
    } else {
      if(userAnswers[i]===true) tBtn.classList.add('selected-t');
      else if(userAnswers[i]===false) fBtn.classList.add('selected-f');
      tBtn.onclick=()=>tfSelect(i,true);
      fBtn.onclick=()=>tfSelect(i,false);
      card.appendChild(stmt); card.appendChild(btns);
    }
    btns.appendChild(tBtn); btns.appendChild(fBtn);
    grid.appendChild(card);
  });
  body.appendChild(grid);

  if(!revealed){
    const allAnswered=userAnswers.every(a=>a!==null);
    if(allAnswered && !answered[cur]){
      // show confirm button
      const cfm=document.createElement('button'); cfm.className='btn primary'; cfm.textContent='Kiểm tra đáp án';
      cfm.style.cssText='width:100%;margin-top:8px';
      cfm.onclick=()=>confirmTF();
      body.appendChild(cfm);
    }
  }
}

let tfTemp=[];
function tfSelect(i,val){
  const q=pool[cur];
  if(!tfTemp.length || tfTemp.length!==q.stmts.length) tfTemp=new Array(q.stmts.length).fill(null);
  tfTemp[i]=val;
  // re-render with updated selections
  const body=document.getElementById('q-body');
  body.innerHTML='';
  const grid=document.createElement('div'); grid.className='tf-opts';
  q.stmts.forEach((s,idx)=>{
    const card=document.createElement('div'); card.className='tf-item';
    const stmt=document.createElement('div'); stmt.className='tf-stmt';
    stmt.innerHTML='<strong>'+s.t.charAt(0)+'.</strong>'+s.t.slice(1);
    const btns=document.createElement('div'); btns.className='tf-btns';
    const tBtn=document.createElement('button'); tBtn.className='tf-btn t-btn'; tBtn.textContent='Đúng';
    const fBtn=document.createElement('button'); fBtn.className='tf-btn f-btn'; fBtn.textContent='Sai';
    if(tfTemp[idx]===true) tBtn.classList.add('selected-t');
    else if(tfTemp[idx]===false) fBtn.classList.add('selected-f');
    tBtn.onclick=()=>tfSelect(idx,true);
    fBtn.onclick=()=>tfSelect(idx,false);
    btns.appendChild(tBtn); btns.appendChild(fBtn);
    card.appendChild(stmt); card.appendChild(btns);
    grid.appendChild(card);
  });
  body.appendChild(grid);
  const allAnswered=tfTemp.every(a=>a!==null);
  if(allAnswered){
    const cfm=document.createElement('button'); cfm.className='btn primary'; cfm.textContent='Kiểm tra đáp án';
    cfm.style.cssText='width:100%;margin-top:8px';
    cfm.onclick=()=>confirmTF();
    body.appendChild(cfm);
  }
}

function confirmTF(){
  const q=pool[cur];
  answered[cur]=[...tfTemp];
  tfTemp=[];
  let numCorrect=0;
  q.stmts.forEach((s,i)=>{ if(answered[cur][i]===s.a) numCorrect++; });
  if(numCorrect===q.stmts.length){ correct++; document.getElementById('s-correct').textContent=correct; document.getElementById('nav-info').textContent='✓ Đúng hết!'; }
  else if(numCorrect===0){ wrong++; document.getElementById('s-wrong').textContent=wrong; document.getElementById('nav-info').textContent='✗ Chưa đúng'; }
  else{ document.getElementById('nav-info').textContent=numCorrect+'/'+q.stmts.length+' đúng'; }
  document.getElementById('btn-next').style.display='';
  renderTF(q);
}

function renderSA(q){
  const body=document.getElementById('q-body');
  body.innerHTML='';
  if(answered[cur]!==null){
    const ans=document.createElement('div'); ans.className='sa-answer';
    ans.innerHTML='<strong>Đáp án</strong>'+q.a+'<br><br><em style="font-size:12px">'+q.e+'</em>';
    body.appendChild(ans);
    document.getElementById('btn-next').style.display='';
  } else {
    const wrap=document.createElement('div'); wrap.className='sa-input-wrap';
    const inp=document.createElement('textarea'); inp.className='sa-input'; inp.placeholder='Nhập câu trả lời của bạn...';
    const sub=document.createElement('button'); sub.className='sa-submit'; sub.textContent='Xem đáp án';
    sub.onclick=()=>answerSA();
    wrap.appendChild(inp); wrap.appendChild(sub);
    body.appendChild(wrap);
    // also add skip-to-answer button
    const show=document.createElement('button'); show.className='btn'; show.textContent='Hiện đáp án ngay';
    show.style='width:100%;margin-top:6px;font-size:12px';
    show.onclick=()=>answerSA();
    body.appendChild(show);
  }
}

function answerSA(){
  answered[cur]=true;
  document.getElementById('nav-info').textContent='Xem đáp án';
  document.getElementById('btn-next').style.display='';
  renderSA(pool[cur]);
}

function go(d){
  if(d>0 && cur===pool.length-1){ showScore(); return; }
  cur=Math.max(0,Math.min(pool.length-1,cur+d));
  tfTemp=[];
  render();
}

function skipQ(){
  if(cur<pool.length-1){ cur++; tfTemp=[]; render(); }
}

function showScore(){
  const pct=Math.round(correct/Math.max(1,pool.length)*100);
  document.getElementById('qcard').innerHTML=`
    <div style="text-align:center;padding:28px 16px">
      <div class="score-circle">
        <div style="font-size:26px;font-weight:700;color:var(--green)">${pct}%</div>
        <div style="font-size:10px;color:var(--green)">điểm số</div>
      </div>
      <div style="font-size:18px;font-weight:600;margin-bottom:8px">${pct>=80?'🌿 Xuất sắc!':pct>=60?'📗 Khá tốt!':'📚 Ôn thêm nhé!'}</div>
      <div style="font-size:13px;color:var(--muted);margin-bottom:20px">Bạn đã hoàn thành ${pool.length} câu hỏi</div>
      <div style="display:flex;gap:12px;justify-content:center;margin-bottom:22px">
        <div style="padding:12px 18px;border-radius:10px;border:1px solid var(--border);text-align:center"><div style="font-size:22px;font-weight:700;color:var(--green)">${correct}</div><div style="font-size:11px;color:var(--muted)">Đúng</div></div>
        <div style="padding:12px 18px;border-radius:10px;border:1px solid var(--border);text-align:center"><div style="font-size:22px;font-weight:700;color:var(--red)">${wrong}</div><div style="font-size:11px;color:var(--muted)">Sai</div></div>
        <div style="padding:12px 18px;border-radius:10px;border:1px solid var(--border);text-align:center"><div style="font-size:22px;font-weight:700;color:var(--blue)">${pool.length-correct-wrong}</div><div style="font-size:11px;color:var(--muted)">Bỏ qua</div></div>
      </div>
      <button class="btn primary" onclick="location.reload()" style="margin-right:8px">Làm lại</button>
    </div>`;
  document.getElementById('nav').style.display='none';
}

// init
setBai('ALL');
setType('ALL');
</script>
</body>
</html>
